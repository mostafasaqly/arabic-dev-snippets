{
  "Angular Component Template": {
    "prefix": "ng-ar-template",
    "scope": "html",
    "body": [
      "<!-- قالب أساسي لكومبوننت أنجولار -->",
      "<div class=\"${1:container}\">",
      "  <h1>{{ ${2:title} }}</h1>",
      "  <ng-content></ng-content>",
      "</div>"
    ],
    "description": "قالب أساسي لجزء من الواجهة"
  },

  "Angular ngFor": {
    "prefix": "ng-ar-for",
    "scope": "html",
    "body": [
      "<!-- بيكرر عنصر لكل بند في المصفوفة -->",
      "<div *ngFor=\"let ${1:item} of ${2:items}; trackBy: trackBy${3:Id}\">",
      "  {{ ${1:item}.${4:name} }}",
      "</div>"
    ],
    "description": "تكرار العنصر لكل بند في المصفوفة"
  },

  "Angular ngIf": {
    "prefix": "ng-ar-if",
    "scope": "html",
    "body": [
      "<!-- بيظهر العنصر بس لو الشرط صح -->",
      "<div *ngIf=\"${1:condition}; else ${2:elseBlock}\">",
      "  ${3:المحتوى هنا}",
      "</div>",
      "<ng-template #${2:elseBlock}>",
      "  ${4:المحتوى البديل}",
      "</ng-template>"
    ],
    "description": "إظهار العنصر إذا تحقق الشرط"
  },

  "Angular New For": {
    "prefix": "ng-ar-for-new",
    "scope": "html",
    "body": [
      "<!-- الطريقة الجديدة في أنجولار 17 للتكرار -->",
      "@for (${1:item} of ${2:items}; track ${1:item}.${3:id}) {",
      "  <div>{{ ${1:item}.${4:name} }}</div>",
      "} @empty {",
      "  <p>${5:مفيش بيانات}</p>",
      "}"
    ],
    "description": "تكرار العناصر بالطريقة الحديثة"
  },

  "Angular New If": {
    "prefix": "ng-ar-if-new",
    "scope": "html",
    "body": [
      "<!-- الطريقة الجديدة في أنجولار 17 للشرط -->",
      "@if (${1:condition}) {",
      "  ${2:المحتوى هنا}",
      "} @else if (${3:otherCondition}) {",
      "  ${4:محتوى آخر}",
      "} @else {",
      "  ${5:المحتوى البديل}",
      "}"
    ],
    "description": "الشرط بالطريقة الحديثة"
  },

  "Angular New Switch": {
    "prefix": "ng-ar-switch-new",
    "scope": "html",
    "body": [
      "<!-- سويتش في أنجولار 17 -->",
      "@switch (${1:status}) {",
      "  @case ('${2:active}') {",
      "    <span class=\"active\">${3:نشط}</span>",
      "  }",
      "  @case ('${4:inactive}') {",
      "    <span class=\"inactive\">${5:غير نشط}</span>",
      "  }",
      "  @default {",
      "    <span>${6:غير معروف}</span>",
      "  }",
      "}"
    ],
    "description": "اختيار من حالات متعددة بالطريقة الحديثة"
  },

  "Angular ngSwitch": {
    "prefix": "ng-ar-switch",
    "scope": "html",
    "body": [
      "<!-- سويتش لعرض عناصر مختلفة حسب القيمة -->",
      "<div [ngSwitch]=\"${1:status}\">",
      "  <span *ngSwitchCase=\"'${2:active}'\">${3:نشط}</span>",
      "  <span *ngSwitchCase=\"'${4:inactive}'\">${5:غير نشط}</span>",
      "  <span *ngSwitchDefault>${6:غير معروف}</span>",
      "</div>"
    ],
    "description": "اختيار من حالات متعددة بالطريقة القديمة"
  },

  "Angular Reactive Form Template": {
    "prefix": "ng-ar-form",
    "scope": "html",
    "body": [
      "<!-- نموذج مرتبط بالفورم جروب -->",
      "<form [formGroup]=\"${1:myForm}\" (ngSubmit)=\"${2:onSubmit}()\">",
      "  <div>",
      "    <label>${3:الاسم}</label>",
      "    <input formControlName=\"${4:name}\" placeholder=\"${3:الاسم}\" />",
      "    <span *ngIf=\"${1:myForm}.get('${4:name}')?.invalid && ${1:myForm}.get('${4:name}')?.touched\">",
      "      ${5:الحقل ده مطلوب}",
      "    </span>",
      "  </div>",
      "  <button type=\"submit\" [disabled]=\"${1:myForm}.invalid\">${6:إرسال}</button>",
      "</form>"
    ],
    "description": "قالب نموذج مرتبط بمجموعة الحقول"
  },

  "Angular Two Way Binding": {
    "prefix": "ng-ar-twoway",
    "scope": "html",
    "body": [
      "<!-- ربط ثنائي الاتجاه بين الكومبوننت والقالب -->",
      "<input [(ngModel)]=\"${1:value}\" placeholder=\"${2:اكتب هنا}\" />"
    ],
    "description": "ربط ثنائي الاتجاه بين الجزء والقالب"
  },

  "Angular Event Binding": {
    "prefix": "ng-ar-event",
    "scope": "html",
    "body": [
      "<!-- ربط حدث بدالة في الكومبوننت -->",
      "<button (click)=\"${1:onClick}($event)\">${2:اضغط هنا}</button>",
      "<input (input)=\"${3:onInput}($event)\" (blur)=\"${4:onBlur}()\" />"
    ],
    "description": "ربط الأحداث بدوال الجزء"
  },

  "Angular Class And Style Binding": {
    "prefix": "ng-ar-class-style",
    "scope": "html",
    "body": [
      "<!-- إضافة كلاس أو ستايل بشكل ديناميكي -->",
      "<div",
      "  [class.${1:active}]=\"${2:isActive}\"",
      "  [class.${3:disabled}]=\"${4:isDisabled}\"",
      "  [style.color]=\"${5:textColor}\"",
      "  [ngClass]=\"{ '${6:highlighted}': ${7:isHighlighted} }\">",
      "  ${8:المحتوى}",
      "</div>"
    ],
    "description": "ربط الأنماط والتنسيقات بشكل ديناميكي"
  },

  "Angular Property Binding": {
    "prefix": "ng-ar-bind",
    "scope": "html",
    "body": [
      "<!-- ربط خاصية بقيمة من الكومبوننت -->",
      "<img [src]=\"${1:imageUrl}\" [alt]=\"${2:imageAlt}\" />",
      "<a [href]=\"${3:link}\" [target]=\"${4:'_blank'}\">${5:رابط}</a>",
      "<button [disabled]=\"${6:isLoading}\">${7:إرسال}</button>"
    ],
    "description": "ربط خصائص العنصر بقيم من الجزء"
  },

  "Angular Defer Lazy Loading": {
    "prefix": "ng-ar-defer",
    "scope": "html",
    "body": [
      "<!-- تحميل الكومبوننت بشكل كسول — بس لما يتحتاج -->",
      "@defer (on viewport) {",
      "  <app-${1:heavy-component} />",
      "} @placeholder {",
      "  <div>${2:جاري التحميل...}</div>",
      "} @loading (minimum 500ms) {",
      "  <div class=\"spinner\">${3:لحظة...}</div>",
      "} @error {",
      "  <div>${4:حصل مشكلة}</div>",
      "}"
    ],
    "description": "تحميل الجزء بشكل كسول عند الحاجة"
  }
}
