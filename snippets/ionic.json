{
  "Ionic Page": {
    "prefix": "ion-ar-page",
    "scope": "typescript",
    "body": [
      "// صفحة أيونيك كاملة جاهزة للاستخدام",
      "import { Component, OnInit } from '@angular/core';",
      "",
      "@Component({",
      "  selector: 'app-${1:home}',",
      "  template: `",
      "    <ion-header>",
      "      <ion-toolbar color=\"primary\">",
      "        <ion-title>${2:الصفحة الرئيسية}</ion-title>",
      "      </ion-toolbar>",
      "    </ion-header>",
      "    <ion-content class=\"ion-padding\">",
      "      <p>${3:مرحباً بك!}</p>",
      "    </ion-content>",
      "  `",
      "})",
      "export class ${4:Home}Page implements OnInit {",
      "  ngOnInit() {}",
      "}"
    ],
    "description": "صفحة كاملة جاهزة للاستخدام"
  },

  "Ionic Modal": {
    "prefix": "ion-ar-modal",
    "scope": "typescript",
    "body": [
      "// نافذة منبثقة — بتظهر فوق الصفحة الحالية",
      "import { ModalController } from '@ionic/angular';",
      "",
      "constructor(private modalCtrl: ModalController) {}",
      "",
      "async ${1:openModal}() {",
      "  const modal = await this.modalCtrl.create({",
      "    component: ${2:MyModal}Component,",
      "    componentProps: { ${3:title}: '${4:عنوان النافذة}' }",
      "  });",
      "  await modal.present();",
      "  const { data } = await modal.onDidDismiss();",
      "  ${5:// استخدم البيانات هنا}",
      "}"
    ],
    "description": "نافذة منبثقة فوق الصفحة الحالية"
  },

  "Ionic Toast": {
    "prefix": "ion-ar-toast",
    "scope": "typescript",
    "body": [
      "// رسالة صغيرة بتظهر وتتخلى لوحدها",
      "import { ToastController } from '@ionic/angular';",
      "",
      "constructor(private toastCtrl: ToastController) {}",
      "",
      "async ${1:showToast}(message: string) {",
      "  const toast = await this.toastCtrl.create({",
      "    message,",
      "    duration: ${2:2000},",
      "    position: '${3:bottom}',",
      "    color: '${4:success}'",
      "  });",
      "  await toast.present();",
      "}"
    ],
    "description": "رسالة صغيرة تظهر وتختفي تلقائياً"
  },

  "Ionic Alert": {
    "prefix": "ion-ar-alert",
    "scope": "typescript",
    "body": [
      "// رسالة تأكيد قبل حذف أو تنفيذ عملية مهمة",
      "import { AlertController } from '@ionic/angular';",
      "",
      "constructor(private alertCtrl: AlertController) {}",
      "",
      "async ${1:confirmDelete}() {",
      "  const alert = await this.alertCtrl.create({",
      "    header: '${2:تأكيد الحذف}',",
      "    message: '${3:هل أنت متأكد؟}',",
      "    buttons: [",
      "      { text: '${4:إلغاء}', role: 'cancel' },",
      "      { text: '${5:حذف}', role: 'confirm', handler: () => this.${6:delete}() }",
      "    ]",
      "  });",
      "  await alert.present();",
      "}"
    ],
    "description": "رسالة تأكيد قبل تنفيذ عملية مهمة"
  },

  "Ionic Loading": {
    "prefix": "ion-ar-loading",
    "scope": "typescript",
    "body": [
      "// مؤشر تحميل أثناء انتظار البيانات",
      "import { LoadingController } from '@ionic/angular';",
      "",
      "constructor(private loadingCtrl: LoadingController) {}",
      "",
      "async ${1:withLoading}(action: () => Promise<any>) {",
      "  const loading = await this.loadingCtrl.create({",
      "    message: '${2:جاري التحميل...}',",
      "    spinner: '${3:crescent}'",
      "  });",
      "  await loading.present();",
      "  try {",
      "    await action();",
      "  } finally {",
      "    await loading.dismiss();",
      "  }",
      "}"
    ],
    "description": "مؤشر تحميل أثناء انتظار البيانات"
  },

  "Ionic Action Sheet": {
    "prefix": "ion-ar-actionsheet",
    "scope": "typescript",
    "body": [
      "// قائمة خيارات بتظهر من تحت الشاشة",
      "import { ActionSheetController } from '@ionic/angular';",
      "",
      "constructor(private actionSheetCtrl: ActionSheetController) {}",
      "",
      "async ${1:showActions}() {",
      "  const actionSheet = await this.actionSheetCtrl.create({",
      "    header: '${2:اختار من القائمة}',",
      "    buttons: [",
      "      { text: '${3:تعديل}', icon: 'create', handler: () => this.${4:edit}() },",
      "      { text: '${5:حذف}', icon: 'trash', role: 'destructive', handler: () => this.${6:delete}() },",
      "      { text: '${7:إلغاء}', role: 'cancel' }",
      "    ]",
      "  });",
      "  await actionSheet.present();",
      "}"
    ],
    "description": "قائمة خيارات تظهر من أسفل الشاشة"
  },

  "Ionic Popover": {
    "prefix": "ion-ar-popover",
    "scope": "typescript",
    "body": [
      "// نافذة صغيرة بتطلع جنب العنصر",
      "import { PopoverController } from '@ionic/angular';",
      "",
      "constructor(private popoverCtrl: PopoverController) {}",
      "",
      "async ${1:showPopover}(event: Event) {",
      "  const popover = await this.popoverCtrl.create({",
      "    component: ${2:MyPopover}Component,",
      "    event,",
      "    translucent: true,",
      "  });",
      "  await popover.present();",
      "}"
    ],
    "description": "نافذة صغيرة تظهر بجانب العنصر"
  },

  "Ionic Navigation": {
    "prefix": "ion-ar-nav",
    "scope": "typescript",
    "body": [
      "// التنقل بين الصفحات في أيونيك",
      "import { NavController } from '@ionic/angular';",
      "",
      "constructor(private navCtrl: NavController) {}",
      "",
      "goTo${1:Details}(id: number) {",
      "  this.navCtrl.navigateForward(`/${2:details}/\\${id}`);",
      "}",
      "",
      "goBack() {",
      "  this.navCtrl.navigateBack('/${3:home}');",
      "}"
    ],
    "description": "التنقل بين صفحات التطبيق"
  },

  "Ionic Storage": {
    "prefix": "ion-ar-storage",
    "scope": "typescript",
    "body": [
      "// حفظ وجلب البيانات من التخزين المحلي",
      "import { Storage } from '@ionic/storage-angular';",
      "",
      "constructor(private storage: Storage) {",
      "  this.storage.create();",
      "}",
      "",
      "async save(key: string, value: any) {",
      "  await this.storage.set(key, value);",
      "}",
      "",
      "async load<T>(key: string): Promise<T | null> {",
      "  return this.storage.get(key);",
      "}",
      "",
      "async remove(key: string) {",
      "  await this.storage.remove(key);",
      "}"
    ],
    "description": "حفظ وجلب البيانات من التخزين المحلي"
  },

  "Ionic Refresher": {
    "prefix": "ion-ar-refresher",
    "scope": "typescript",
    "body": [
      "// بيسمح المستخدم يسحب الصفحة لأسفل لتحديث البيانات",
      "async ${1:doRefresh}(event: any) {",
      "  try {",
      "    await this.${2:loadData}();",
      "  } finally {",
      "    event.target.complete();",
      "  }",
      "}"
    ],
    "description": "تحديث البيانات بالسحب لأسفل"
  },

  "Ionic Infinite Scroll": {
    "prefix": "ion-ar-infinite",
    "scope": "typescript",
    "body": [
      "// تحميل بيانات إضافية لما المستخدم يوصل لآخر الصفحة",
      "page = 1;",
      "",
      "async ${1:loadMore}(event: any) {",
      "  this.page++;",
      "  const newItems = await this.${2:service}.getPage(this.page);",
      "  this.${3:items}.push(...newItems);",
      "  event.target.complete();",
      "  if (newItems.length < ${4:10}) {",
      "    event.target.disabled = true;",
      "  }",
      "}"
    ],
    "description": "تحميل بيانات إضافية عند نهاية الصفحة"
  },

  "Ionic Camera": {
    "prefix": "ion-ar-camera",
    "scope": "typescript",
    "body": [
      "// التقاط صورة من الكاميرا أو الاستوديو",
      "import { Camera, CameraResultType, CameraSource } from '@capacitor/camera';",
      "",
      "async ${1:takePhoto}() {",
      "  const photo = await Camera.getPhoto({",
      "    quality: 90,",
      "    allowEditing: false,",
      "    resultType: CameraResultType.DataUrl,",
      "    source: CameraSource.Camera,",
      "  });",
      "  this.${2:imageUrl} = photo.dataUrl;",
      "}",
      "",
      "async ${3:pickFromGallery}() {",
      "  const photo = await Camera.getPhoto({",
      "    quality: 90,",
      "    resultType: CameraResultType.DataUrl,",
      "    source: CameraSource.Photos,",
      "  });",
      "  this.${2:imageUrl} = photo.dataUrl;",
      "}"
    ],
    "description": "التقاط صورة من الكاميرا أو معرض الصور"
  }
}
