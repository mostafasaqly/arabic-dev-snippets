{
  "موديول نيست": {
    "prefix": "nest-ar-module",
    "scope": "typescript",
    "body": [
      "// بينظم الكود في وحدات — لكل فيتشر ليها موديول خاص",
      "import { Module } from '@nestjs/common';",
      "import { ${1:Users}Controller } from './${2:users}.controller';",
      "import { ${1:Users}Service } from './${2:users}.service';",
      "",
      "@Module({",
      "  controllers: [${1:Users}Controller],",
      "  providers: [${1:Users}Service],",
      "  exports: [${1:Users}Service]",
      "})",
      "export class ${1:Users}Module {}"
    ],
    "description": "موديول نيست جي اس كامل"
  },

  "كونترولر نيست": {
    "prefix": "nest-ar-controller",
    "scope": "typescript",
    "body": [
      "// بيستقبل الطلبات ويرجع الردود",
      "import { Controller, Get, Post, Put, Delete, Body, Param } from '@nestjs/common';",
      "import { ${1:Users}Service } from './${2:users}.service';",
      "import { Create${3:User}Dto } from './dto/create-${2:user}.dto';",
      "",
      "@Controller('${4:users}')",
      "export class ${1:Users}Controller {",
      "  constructor(private readonly ${5:usersService}: ${1:Users}Service) {}",
      "",
      "  @Get()",
      "  findAll() {",
      "    return this.${5:usersService}.findAll();",
      "  }",
      "",
      "  @Get(':id')",
      "  findOne(@Param('id') id: string) {",
      "    return this.${5:usersService}.findOne(+id);",
      "  }",
      "",
      "  @Post()",
      "  create(@Body() dto: Create${3:User}Dto) {",
      "    return this.${5:usersService}.create(dto);",
      "  }",
      "",
      "  @Delete(':id')",
      "  remove(@Param('id') id: string) {",
      "    return this.${5:usersService}.remove(+id);",
      "  }",
      "}"
    ],
    "description": "كونترولر نيست جي اس كامل"
  },

  "سيرفيس نيست": {
    "prefix": "nest-ar-service",
    "scope": "typescript",
    "body": [
      "// منطق العمل الرئيسي — بعيد عن طبقة الطلبات",
      "import { Injectable, NotFoundException } from '@nestjs/common';",
      "import { PrismaService } from '../prisma/prisma.service';",
      "import { Create${1:User}Dto } from './dto/create-${2:user}.dto';",
      "",
      "@Injectable()",
      "export class ${3:Users}Service {",
      "  constructor(private prisma: PrismaService) {}",
      "",
      "  async findAll() {",
      "    return this.prisma.${2:user}.findMany();",
      "  }",
      "",
      "  async findOne(id: number) {",
      "    const item = await this.prisma.${2:user}.findUnique({ where: { id } });",
      "    if (!item) throw new NotFoundException('مش موجود');",
      "    return item;",
      "  }",
      "",
      "  async create(dto: Create${1:User}Dto) {",
      "    return this.prisma.${2:user}.create({ data: dto });",
      "  }",
      "",
      "  async remove(id: number) {",
      "    return this.prisma.${2:user}.delete({ where: { id } });",
      "  }",
      "}"
    ],
    "description": "سيرفيس نيست جي اس كامل"
  },

  "دي تي أو نيست": {
    "prefix": "nest-ar-dto",
    "scope": "typescript",
    "body": [
      "// بيحدد شكل البيانات الجاية ويتحقق منها",
      "import { IsString, IsEmail, IsOptional, MinLength } from 'class-validator';",
      "",
      "export class Create${1:User}Dto {",
      "  @IsString()",
      "  ${2:name}: string;",
      "",
      "  @IsEmail()",
      "  ${3:email}: string;",
      "",
      "  @MinLength(8)",
      "  ${4:password}: string;",
      "}",
      "",
      "export class Update${1:User}Dto {",
      "  @IsOptional()",
      "  @IsString()",
      "  ${2:name}?: string;",
      "",
      "  @IsOptional()",
      "  @IsEmail()",
      "  ${3:email}?: string;",
      "}"
    ],
    "description": "دي تي أو نيست جي اس"
  },

  "جارد نيست": {
    "prefix": "nest-ar-guard",
    "scope": "typescript",
    "body": [
      "// بيتحقق من صلاحية المستخدم قبل أي طلب",
      "import { CanActivate, ExecutionContext, Injectable, UnauthorizedException } from '@nestjs/common';",
      "import { JwtService } from '@nestjs/jwt';",
      "",
      "@Injectable()",
      "export class ${1:Auth}Guard implements CanActivate {",
      "  constructor(private jwtService: JwtService) {}",
      "",
      "  canActivate(context: ExecutionContext): boolean {",
      "    const request = context.switchToHttp().getRequest();",
      "    const token = request.headers.authorization?.split(' ')[1];",
      "    if (!token) throw new UnauthorizedException('محتاج تسجل دخول الأول');",
      "    try {",
      "      request.user = this.jwtService.verify(token);",
      "      return true;",
      "    } catch {",
      "      throw new UnauthorizedException('التوكن مش صحيح');",
      "    }",
      "  }",
      "}"
    ],
    "description": "جارد نيست جي اس للتحقق من الصلاحيات"
  },

  "بايب نيست": {
    "prefix": "nest-ar-pipe",
    "scope": "typescript",
    "body": [
      "// بيتحقق من البيانات أو بيحولها قبل ما توصل للكونترولر",
      "import { PipeTransform, Injectable, BadRequestException } from '@nestjs/common';",
      "",
      "@Injectable()",
      "export class ${1:ParseId}Pipe implements PipeTransform {",
      "  transform(value: string) {",
      "    const id = parseInt(value);",
      "    if (isNaN(id)) throw new BadRequestException('المعرف مش رقم صحيح');",
      "    return id;",
      "  }",
      "}"
    ],
    "description": "بايب نيست جي اس للتحقق من البيانات"
  },

  "انترسيبتور نيست": {
    "prefix": "nest-ar-interceptor",
    "scope": "typescript",
    "body": [
      "// بيلتقط الطلب والرد ويتحكم فيهم",
      "import { Injectable, NestInterceptor, ExecutionContext, CallHandler } from '@nestjs/common';",
      "import { Observable } from 'rxjs';",
      "import { map } from 'rxjs/operators';",
      "",
      "@Injectable()",
      "export class ${1:Transform}Interceptor implements NestInterceptor {",
      "  intercept(context: ExecutionContext, next: CallHandler): Observable<any> {",
      "    return next.handle().pipe(",
      "      map(data => ({",
      "        data,",
      "        success: true,",
      "        timestamp: new Date().toISOString(),",
      "      }))",
      "    );",
      "  }",
      "}"
    ],
    "description": "انترسيبتور نيست جي اس لتحويل الردود"
  },

  "فلتر استثناءات نيست": {
    "prefix": "nest-ar-filter",
    "scope": "typescript",
    "body": [
      "// بيمسك الأخطاء ويرجع رسالة واضحة",
      "import { ExceptionFilter, Catch, ArgumentsHost, HttpException, HttpStatus } from '@nestjs/common';",
      "import { Response } from 'express';",
      "",
      "@Catch()",
      "export class ${1:All}ExceptionsFilter implements ExceptionFilter {",
      "  catch(exception: unknown, host: ArgumentsHost) {",
      "    const ctx = host.switchToHttp();",
      "    const response = ctx.getResponse<Response>();",
      "",
      "    const status = exception instanceof HttpException",
      "      ? exception.getStatus()",
      "      : HttpStatus.INTERNAL_SERVER_ERROR;",
      "",
      "    response.status(status).json({",
      "      success: false,",
      "      statusCode: status,",
      "      message: exception instanceof HttpException",
      "        ? exception.message",
      "        : 'حصل خطأ في السيرفر',",
      "    });",
      "  }",
      "}"
    ],
    "description": "فلتر الاستثناءات في نيست جي اس"
  },

  "ديكوريتور مستخدم": {
    "prefix": "nest-ar-decorator",
    "scope": "typescript",
    "body": [
      "// ديكوريتور مخصص لجلب بيانات من الطلب",
      "import { createParamDecorator, ExecutionContext } from '@nestjs/common';",
      "",
      "export const ${1:CurrentUser} = createParamDecorator(",
      "  (data: string | undefined, ctx: ExecutionContext) => {",
      "    const request = ctx.switchToHttp().getRequest();",
      "    const user = request.user;",
      "    return data ? user?.[data] : user;",
      "  },",
      ");"
    ],
    "description": "ديكوريتور مخصص في نيست جي اس"
  },

