{
  "Prisma Model (عربي)": {
    "prefix": "pr-ar-model",
    "scope": "prisma",
    "body": [
      "// تعريف جدول في الـ database — لكل field نوع وخصائص",
      "model ${1:User} {",
      "  id        Int      @id @default(autoincrement())",
      "  ${2:name}      String",
      "  ${3:email}     String   @unique",
      "  ${4:password}  String",
      "  createdAt DateTime @default(now())",
      "  updatedAt DateTime @updatedAt",
      "}"
    ],
    "description": "إنشاء Prisma model بشرح عربي — تعريف جدول في الـ database"
  },

  "Prisma findMany (عربي)": {
    "prefix": "pr-ar-findmany",
    "scope": "typescript",
    "body": [
      "// جيب كل السجلات مع إمكانية الفلترة والترتيب",
      "const ${1:items} = await prisma.${2:user}.findMany({",
      "  where: { ${3:isActive}: ${4:true} },      // فلتر",
      "  orderBy: { ${5:createdAt}: '${6:desc}' }, // ترتيب",
      "  skip: ${7:0},                             // للـ pagination",
      "  take: ${8:10},                            // عدد النتايج",
      "});"
    ],
    "description": "Prisma findMany بشرح عربي — جيب كل السجلات مع الفلترة"
  },

  "Prisma findUnique (عربي)": {
    "prefix": "pr-ar-findone",
    "scope": "typescript",
    "body": [
      "// جيب سجل واحد بالـ ID أو أي field فريد",
      "const ${1:item} = await prisma.${2:user}.findUnique({",
      "  where: { id: ${3:id} },",
      "  include: { ${4:posts}: true }, // جيب الـ relations معاه",
      "});"
    ],
    "description": "Prisma findUnique بشرح عربي — جيب سجل واحد بالـ ID"
  },

  "Prisma create (عربي)": {
    "prefix": "pr-ar-create",
    "scope": "typescript",
    "body": [
      "// إضافة سجل جديد في الـ database",
      "const ${1:newItem} = await prisma.${2:user}.create({",
      "  data: {",
      "    ${3:name}: ${4:'أحمد'},",
      "    ${5:email}: ${6:'ahmed@example.com'},",
      "    $0",
      "  },",
      "});"
    ],
    "description": "Prisma create بشرح عربي — إضافة سجل جديد"
  },

  "Prisma update (عربي)": {
    "prefix": "pr-ar-update",
    "scope": "typescript",
    "body": [
      "// تعديل سجل موجود بالـ ID",
      "const ${1:updated} = await prisma.${2:user}.update({",
      "  where: { id: ${3:id} },",
      "  data: { ${4:name}: ${5:'اسم جديد'} },",
      "});"
    ],
    "description": "Prisma update بشرح عربي — تعديل سجل موجود"
  },

  "Prisma delete (عربي)": {
    "prefix": "pr-ar-delete",
    "scope": "typescript",
    "body": [
      "// حذف سجل من الـ database",
      "const ${1:deleted} = await prisma.${2:user}.delete({",
      "  where: { id: ${3:id} },",
      "});"
    ],
    "description": "Prisma delete بشرح عربي — حذف سجل من الـ database"
  },

  "Prisma Relation (عربي)": {
    "prefix": "pr-ar-relation",
    "scope": "prisma",
    "body": [
      "// ربط جدولين ببعض — One-to-Many",
      "model ${1:Post} {",
      "  id     Int    @id @default(autoincrement())",
      "  ${2:title}  String",
      "  ${3:userId} Int",
      "  ${4:user}   ${5:User}   @relation(fields: [${3:userId}], references: [id])",
      "}",
      "",
      "model ${5:User} {",
      "  id    Int     @id @default(autoincrement())",
      "  ${6:posts} ${1:Post}[]",
      "}"
    ],
    "description": "إنشاء Prisma relation بشرح عربي — ربط جدولين ببعض"
  }
}
