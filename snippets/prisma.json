{
  "Prisma Model": {
    "prefix": "pr-ar-model",
    "scope": "prisma",
    "body": [
      "// تعريف جدول في قاعدة البيانات — لكل حقل نوع وخصائص",
      "model ${1:User} {",
      "  id        Int      @id @default(autoincrement())",
      "  ${2:name}      String",
      "  ${3:email}     String   @unique",
      "  ${4:password}  String",
      "  createdAt DateTime @default(now())",
      "  updatedAt DateTime @updatedAt",
      "}"
    ],
    "description": "تعريف جدول في قاعدة البيانات"
  },

  "Prisma Find Many": {
    "prefix": "pr-ar-findmany",
    "scope": "typescript",
    "body": [
      "// جيب كل السجلات مع إمكانية الفلترة والترتيب",
      "const ${1:items} = await prisma.${2:user}.findMany({",
      "  where: { ${3:isActive}: ${4:true} },",
      "  orderBy: { ${5:createdAt}: '${6:desc}' },",
      "  skip: ${7:0},",
      "  take: ${8:10},",
      "});"
    ],
    "description": "جلب كل السجلات مع فلترة وترتيب"
  },

  "Prisma Find One": {
    "prefix": "pr-ar-findone",
    "scope": "typescript",
    "body": [
      "// جيب سجل واحد بالمعرف أو أي حقل فريد",
      "const ${1:item} = await prisma.${2:user}.findUnique({",
      "  where: { id: ${3:id} },",
      "  include: { ${4:posts}: true },",
      "});"
    ],
    "description": "جلب سجل واحد بالمعرف"
  },

  "Prisma Create": {
    "prefix": "pr-ar-create",
    "scope": "typescript",
    "body": [
      "// إضافة سجل جديد في قاعدة البيانات",
      "const ${1:newItem} = await prisma.${2:user}.create({",
      "  data: {",
      "    ${3:name}: ${4:'أحمد'},",
      "    ${5:email}: ${6:'ahmed@example.com'},",
      "    $0",
      "  },",
      "});"
    ],
    "description": "إضافة سجل جديد إلى قاعدة البيانات"
  },

  "Prisma Update": {
    "prefix": "pr-ar-update",
    "scope": "typescript",
    "body": [
      "// تعديل سجل موجود بالمعرف",
      "const ${1:updated} = await prisma.${2:user}.update({",
      "  where: { id: ${3:id} },",
      "  data: { ${4:name}: ${5:'اسم جديد'} },",
      "});"
    ],
    "description": "تعديل سجل موجود بالمعرف"
  },

  "Prisma Delete": {
    "prefix": "pr-ar-delete",
    "scope": "typescript",
    "body": [
      "// حذف سجل من قاعدة البيانات",
      "const ${1:deleted} = await prisma.${2:user}.delete({",
      "  where: { id: ${3:id} },",
      "});"
    ],
    "description": "حذف سجل من قاعدة البيانات"
  },

  "Prisma One To Many Relation": {
    "prefix": "pr-ar-relation",
    "scope": "prisma",
    "body": [
      "// ربط جدولين ببعض — علاقة واحد لكثير",
      "model ${1:Post} {",
      "  id     Int    @id @default(autoincrement())",
      "  ${2:title}  String",
      "  ${3:userId} Int",
      "  ${4:user}   ${5:User}   @relation(fields: [${3:userId}], references: [id])",
      "}",
      "",
      "model ${5:User} {",
      "  id    Int     @id @default(autoincrement())",
      "  ${6:posts} ${1:Post}[]",
      "}"
    ],
    "description": "علاقة واحد لكثير بين جدولين"
  },

  "Prisma Many To Many Relation": {
    "prefix": "pr-ar-many-to-many",
    "scope": "prisma",
    "body": [
      "// علاقة كثير لكثير — طالب في أكتر من كورس والعكس",
      "model ${1:Student} {",
      "  id      Int       @id @default(autoincrement())",
      "  name    String",
      "  courses ${2:Course}[]",
      "}",
      "",
      "model ${2:Course} {",
      "  id       Int        @id @default(autoincrement())",
      "  title    String",
      "  students ${1:Student}[]",
      "}"
    ],
    "description": "علاقة كثير لكثير بين جدولين"
  },

  "Prisma Transaction": {
    "prefix": "pr-ar-transaction",
    "scope": "typescript",
    "body": [
      "// تنفيذ أكتر من عملية مع بعض — لو واحدة فشلت كلهم بيرجعوا",
      "const [${1:user}, ${2:wallet}] = await prisma.$transaction([",
      "  prisma.${3:user}.create({",
      "    data: { ${4:name}: '${5:أحمد}', ${6:email}: '${7:ahmed@example.com}' },",
      "  }),",
      "  prisma.${8:wallet}.create({",
      "    data: { ${9:balance}: 0 },",
      "  }),",
      "]);"
    ],
    "description": "تنفيذ عمليات متعددة معاً بأمان"
  },

  "Prisma Pagination": {
    "prefix": "pr-ar-pagination",
    "scope": "typescript",
    "body": [
      "// تقسيم النتايج لصفحات",
      "async function ${1:paginate}(page: number, limit: number) {",
      "  const skip = (page - 1) * limit;",
      "  const [${2:items}, total] = await prisma.$transaction([",
      "    prisma.${3:user}.findMany({ skip, take: limit }),",
      "    prisma.${3:user}.count(),",
      "  ]);",
      "  return {",
      "    ${2:items},",
      "    total,",
      "    page,",
      "    totalPages: Math.ceil(total / limit),",
      "    hasNext: page * limit < total,",
      "  };",
      "}"
    ],
    "description": "تقسيم النتائج إلى صفحات"
  },

  "Prisma Search": {
    "prefix": "pr-ar-search",
    "scope": "typescript",
    "body": [
      "// بحث في أكتر من حقل",
      "const ${1:results} = await prisma.${2:user}.findMany({",
      "  where: {",
      "    OR: [",
      "      { ${3:name}: { contains: ${4:query}, mode: 'insensitive' } },",
      "      { ${5:email}: { contains: ${4:query}, mode: 'insensitive' } },",
      "    ],",
      "  },",
      "});"
    ],
    "description": "البحث في أكثر من حقل معاً"
  },

  "Prisma Upsert": {
    "prefix": "pr-ar-upsert",
    "scope": "typescript",
    "body": [
      "// لو موجود حدثه — لو مش موجود ضيفه",
      "const ${1:record} = await prisma.${2:user}.upsert({",
      "  where: { ${3:email}: '${4:ahmed@example.com}' },",
      "  update: { ${5:name}: '${6:أحمد محدث}' },",
      "  create: {",
      "    ${3:email}: '${4:ahmed@example.com}',",
      "    ${5:name}: '${6:أحمد}',",
      "  },",
      "});"
    ],
    "description": "إضافة سجل أو تحديثه إن كان موجوداً"
  },

  "Prisma Delete Many": {
    "prefix": "pr-ar-deletemany",
    "scope": "typescript",
    "body": [
      "// حذف أكتر من سجل بشرط معين",
      "const { count } = await prisma.${1:user}.deleteMany({",
      "  where: {",
      "    ${2:isActive}: ${3:false},",
      "    createdAt: {",
      "      lt: new Date(Date.now() - 30 * 24 * 60 * 60 * 1000), // قبل 30 يوم",
      "    },",
      "  },",
      "});",
      "console.log(`تم حذف \\${count} سجل`);"
    ],
    "description": "حذف عدة سجلات بشرط معين"
  },

  "Prisma Aggregate": {
    "prefix": "pr-ar-aggregate",
    "scope": "typescript",
    "body": [
      "// إحصائيات — المجموع والمتوسط والأقصى والأقل",
      "const stats = await prisma.${1:order}.aggregate({",
      "  _sum: { ${2:amount}: true },",
      "  _avg: { ${2:amount}: true },",
      "  _max: { ${2:amount}: true },",
      "  _min: { ${2:amount}: true },",
      "  _count: { id: true },",
      "  where: { ${3:status}: '${4:completed}' },",
      "});"
    ],
    "description": "حساب إحصائيات المجموع والمتوسط والحدود"
  }
}
